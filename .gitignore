# Python caches and build outputs
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.so
build/
dist/
*.egg

# Local environments
.venv/
venv/
.env
.env.*

# Local run outputs
outputs/

# Local-only data (test data not committed — new users need their own)
data/

# Step marker files (generated by setup scripts)
setup-step*-ok

# Dependency lock files (generated for reproducibility; uv.lock is committed)
requirements-lock.txt
requirements.txt

# Third-party cloned tools (ignore everything under tools/ except the registry)
tools/*
!tools/urls.yaml

# Frontend local artifacts
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Editor / OS noise
.vscode/
.DS_Store
*.swp
*.swo
*~

# Jupyter notebooks (if any)
.ipynb_checkpoints/

# Coverage reports
htmlcov/
.coverage
coverage.xml
